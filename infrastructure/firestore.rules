rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow read: if false; // sessions are server-side only
    }

    match /metrics/servers {
      allow read: if true;
      allow write: if request.auth.token.admin == true; // admin only
    }

    match /decisions/{docId} {
      allow read, write: if request.auth != null; // server writes via admin SDK
    }

    match /users/{uid} {
      allow create, read, update: if request.auth != null && request.auth.uid == uid;
    }
  }
}
