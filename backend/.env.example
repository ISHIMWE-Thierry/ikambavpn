PORT=3000
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
REAL_METRICS=false
MOCK_WG_ENDPOINT_USA=us.example.com:51820
MOCK_WG_ENDPOINT_RWANDA=rw.example.com:51820
MOCK_WG_PUBLIC_KEY_USA=server-public-key-us
MOCK_WG_PUBLIC_KEY_RWANDA=server-public-key-rw
PROVIDER_A_USA_ENDPOINT=usa-a.example.com:51820
PROVIDER_A_USA_PUBKEY=providerA-usa-pubkey
PROVIDER_A_RW_ENDPOINT=rw-a.example.com:51820
PROVIDER_A_RW_PUBKEY=providerA-rw-pubkey
PROVIDER_B_USA_ENDPOINT=usa-b.example.com:51820
PROVIDER_B_USA_PUBKEY=providerB-usa-pubkey
PROVIDER_B_RW_ENDPOINT=rw-b.example.com:51820
PROVIDER_B_RW_PUBKEY=providerB-rw-pubkey
PROVIDER_A_DNS=1.1.1.1
PROVIDER_B_DNS=1.0.0.1

# ── 3X-UI Panel (VLESS+REALITY for Russia) ──
# IMPORTANT: XPANEL_URL must include the webBasePath suffix if configured.
# Example with default port: https://your-vps-ip:2053
# Example with custom port + path: https://your-vps-ip:39182/x7kQ9m
# The port MUST match what 3X-UI is actually listening on.
# Run `x-ui setting -show` on the VPS to verify.
XPANEL_URL=https://your-vps-ip:2053
XPANEL_USER=ikamba
XPANEL_PASS=your-panel-password
XPANEL_INBOUND_ID=1
XPANEL_SUB_URL=https://your-vps-ip:2096/sub
XPANEL_VPS_IP=your-vps-ip
XPANEL_REALITY_PUBLIC_KEY=your-reality-public-key
XPANEL_REALITY_SHORT_ID=your-short-id
